<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Parámetros generales -->
  <xacro:arg name="package_name" default="my_robot_description"/>
  <!-- Le pasas de donde va a sacar los modelos-->
  <xacro:arg name="mesh_dir" default="meshes"/> 

  <!-- Escala global del modelo CAD exportado desde SolidWorks -->
  <xacro:property name="global_scale" value="1.0"/>

  <!-- Base -->
  <xacro:property name="base_mesh" value="base_link.STL"/>
  <xacro:property name="base_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="base_visual_xyz" value="0 0 0"/>
  <!--ARRIBA PARA POSICION Y ABAJO PARA ROTACION-->
  <xacro:property name="base_visual_rpy" value="0 0 0"/>

  <!-- Rueda izquierda -->
  <xacro:property name="left_wheel_mesh" value="Rueda_izquierda_link.STL"/>
  <xacro:property name="left_wheel_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="left_wheel_xyz" value="-0.033259 0.08025 -0.01375"/>
  <!--lo ubica en el sector donde va a spawnear, fijate que la izquierda esta del otro lado que la derecha-->
  <xacro:property name="left_wheel_rpy" value="0 0 0"/>
  <xacro:property name="left_wheel_axis" value="0 1 0"/>
    <!--lo que hace es decir sobre que eje gira en este caso el y-->
  <xacro:property name="left_wheel_visual_xyz" value="0 0 0"/>
  <!-- ubica visulamente donde va a estar-->
  <xacro:property name="left_wheel_visual_rpy" value="-1.5708 0.042481 0"/>

  <!-- Rueda derecha -->
  <xacro:property name="right_wheel_mesh" value="Rueda_derecha_link.STL"/>
  <xacro:property name="right_wheel_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="right_wheel_xyz" value="-0.033259 -0.08025 -0.01375"/>
  <xacro:property name="right_wheel_rpy" value="0 0 0"/>
  <xacro:property name="right_wheel_axis" value="0 1 0"/>

  <!-- Soporte castor-->
  <xacro:property name="castor_base_mesh" value="Base_castor_link.STL"/>
  <xacro:property name="castor_base_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="castor_base_xyz" value="0.072581 0 -0.0025"/>
  <xacro:property name="castor_base_rpy" value="${valor_pi} ${valor_pi} ${valor_pi}"/>
  <xacro:property name="castor_base_axis" value="0 0 1"/>
  <xacro:property name="castor_base_visual_xyz" value="0 0 0"/>
  <xacro:property name="castor_base_visual_rpy" value="${valor_pi} 0 ${valor_pi}"/>

  <!-- Rueda castor -->
  <xacro:property name="castor_wheel_mesh" value="Rueda_castor_link.STL"/>
  <xacro:property name="castor_wheel_scale" value="${global_scale+0.5} ${global_scale+0.5} ${global_scale}"/>
  <xacro:property name="castor_wheel_xyz" value="-0.015014 -0.00012272 -0.02296"/>
  <xacro:property name="castor_wheel_rpy" value="${valor_pi} ${valor_pi} -${valor_pi}"/>
  <xacro:property name="castor_wheel_axis" value="0 1 0"/>
  <xacro:property name="castor_wheel_visual_xyz" value="0 0 0"/>
  <xacro:property name="castor_wheel_visual_rpy" value="${media_pi} 0 0"/>

  <!-- Parámetros geométricos de referencia para usar en control/TF -->
  <!-- No se usan explicitamente, pero sirven para dejar documentadas las dimensiones principales -->
  <xacro:property name="wheel_separation" value="0.1605"/>
  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="robot_length" value="0.185"/>
  <xacro:property name="robot_width" value="0.145"/>
  <xacro:property name="robot_height" value="0.050"/>
  <xacro:property name="base_x" value="0.21"/>
  <xacro:property name="base_y" value="0.15"/>
  <xacro:property name="base_z" value="0.050"/>
  <xacro:property name="base_mass" value="0.12"/>

  <xacro:property name="wheel_mass" value="0.1403"/>
  <xacro:property name="wheel_width" value="0.025"/>

  <xacro:property name="castor_wheel_radius" value="0.021"/>
  <xacro:property name="castor_wheel_width" value="0.020"/>
  <xacro:property name="castor_wheel_mass" value="0.086"/>

  <!-- <xacro:include filename="my_robot_gazebo.xacro" />  Lo saque para probar-->
  <!-- Macros auxiliares -->
  <xacro:macro name="box_inertia" params="m x y z o_xyz o_rpy">
    <inertial>
        <mass value="${m}"/>
        <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
        <inertia ixx="${(m/12) * (y*y + z*z)}" ixy="0" ixz="0"
                 iyy="${(m/12) * (x*x + z*z)}" iyz="0"
                 izz="${(m/12) * (x*x + y*y)}"/>
      </inertial>
  </xacro:macro>
  
  <xacro:macro name="cylinder_inertia" params="m r h o_xyz o_rpy">
    <inertial>
        <mass value="${m}"/>
        <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
        <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0"
                 iyy="${(m/12) * (3*r*r + h*h)}" iyz="0"
                 izz="${(m/2) * (r*r)}"/>
      </inertial>
  </xacro:macro>

  <!-- Link tipo caja -->
  <xacro:macro name="mesh_link_box" params="name mesh scale m x y z o_xyz o_rpy">
    <link name="${name}">

      <visual>
        <origin xyz="${base_visual_xyz}" rpy="${base_visual_rpy}"/>
        <geometry>
          <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${mesh}" scale="${scale}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <geometry>
          <box size="${x} ${y} ${z}"/>
        </geometry>
        <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      </collision>

      <xacro:box_inertia m="${m}" x="${x}" y="${y}" z="${z}" o_xyz="${o_xyz}" o_rpy="${o_rpy}"/>

    </link>
  </xacro:macro>

  <!-- Link tipo esfera -->
  <xacro:macro name="mesh_link_sphere" params="name mesh scale m r h o_xyz o_rpy">
    <link name="${name}">

      <visual>
        <origin xyz="${left_wheel_visual_xyz}" rpy="${left_wheel_visual_rpy}"/>
        <geometry>
          <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${mesh}" scale="${scale}"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${r}"/>
        </geometry>
        <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      </collision>

      <xacro:cylinder_inertia m="${m}" r="${r}" h="${h}" o_xyz="${o_xyz}" o_rpy="${o_rpy}"/>
    </link>
  </xacro:macro>

  <!-- Completar Macro-Link caja castor -->
  <xacro:macro name="mesh_link_castor" params="name mesh scale">
    <link name="${name}">

      <visual>
        <origin xyz="${castor_base_visual_xyz}" rpy="${castor_base_visual_rpy}"/>
        <geometry>
          <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${mesh}" scale="${scale}"/>
        </geometry>
        <material name="green"/>
      </visual>

    </link>
  </xacro:macro>
  <!-- Completar Macro-Link rueda castor-->
  <xacro:macro name="mesh_link_rueda_castor" params="name mesh scale m r h o_xyz o_rpy">
    <link name="${name}">

      <visual>
        <origin xyz="${castor_wheel_visual_xyz}" rpy="${castor_wheel_visual_rpy}"/>
        <geometry>
          <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${mesh}" scale="${scale}"/>
        </geometry>
        <material name="yellow"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${r}"/>
        </geometry>
        <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      </collision>

      <xacro:cylinder_inertia m="${m}" r="${r}" h="${h}" o_xyz="${o_xyz}" o_rpy="${o_rpy}"/>
    </link>
  </xacro:macro>
  <!-- Instancia de Macros-links -->
  <link name="base_footprint" />

  <xacro:mesh_link_box
    name="base_link"
    mesh="${base_mesh}"
    scale="${base_scale}"
    m="${base_mass}"
    x="${base_x}" 
    y="${base_y}" 
    z="${base_z}"
    o_xyz="0 0 0" 
    o_rpy="0 0 0"/>

  <xacro:mesh_link_sphere
    name="Rueda_izquierda_link"
    mesh="${left_wheel_mesh}"
    scale="${left_wheel_scale}"
    m="${wheel_mass}"
    r="${wheel_radius}"
    h="${wheel_width}"
    o_xyz="0 0 0"
    o_rpy="${media_pi} 0 0"/>

 <!-- Completar Instancia Link rueda rueda derecha-->
  <xacro:mesh_link_sphere
    name="Rueda_derecha_link"
    mesh="${right_wheel_mesh}"
    scale="${right_wheel_scale}"
    m="${wheel_mass}"
    r="${wheel_radius}"
    h="${wheel_width}"
    o_xyz="0 0 0"
    o_rpy="${media_pi} 0 0"/>
 <!-- Completar Instancia Link caja castor-->
  <xacro:mesh_link_castor
    name="Base_castor_link"
    mesh="${castor_base_mesh}"
    scale="${castor_base_scale}"/>

 <!-- Completar Instancia Link rueda castor-->
  <xacro:mesh_link_rueda_castor
    name="Rueda_castor_link"
    mesh="${castor_wheel_mesh}"
    scale="${castor_wheel_scale}"
    m="${castor_wheel_mass}"
    r="${castor_wheel_radius}"
    h="${castor_wheel_width}"
    o_xyz="0 0 0"
    o_rpy="${media_pi} 0 0"/>

  <link name="Lidar_link">
    <inertial>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="1e-6" ixy="0" ixz="0"
                 iyy="1e-6" iyz="0"
                 izz="1e-6"/>
    </inertial>
    <visual>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <geometry>
            <cylinder radius="0.025" length="0.02"/>
        </geometry>
        <material name=""><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <geometry>
            <cylinder radius="0.025" length="0.02"/>
        </geometry>
    </collision>
  </link>

  <!-- Joints -->
  <joint name="base_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0.04675" rpy="0 0 0"/>
  </joint>

  <joint name="Rueda_izquierda_joint" type="continuous">
    <origin xyz="${left_wheel_xyz}" rpy="${left_wheel_rpy}"/>
    <parent link="base_link"/>
    <child link="Rueda_izquierda_link"/>
    <axis xyz="${left_wheel_axis}"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

 <!-- Completar Joint rueda_derecha_link>base_link-->
  <joint name="Rueda_derecha_joint" type="continuous">
    <origin xyz="${right_wheel_xyz}" rpy="${right_wheel_rpy}"/>
    <parent link="base_link"/>
    <child link="Rueda_derecha_link"/>
    <axis xyz="${right_wheel_axis}"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>  
 <!-- Completar Joint Base_castor_link>base_link-->
  <joint name="Base_castor_joint" type="fixed">
    <origin xyz="${castor_base_xyz}" rpy="${castor_base_rpy}"/>
    <parent link="base_link"/>
    <child link="Base_castor_link"/>
    <axis xyz="${castor_base_axis}"/>
  </joint>
 <!-- Compĺetar Joint rueda_castor_link>Base_castor_link-->
  <joint name="Rueda_castor_joint" type="continuous">
    <origin xyz="${castor_wheel_xyz}" rpy="${castor_wheel_rpy}"/>
    <parent link="Base_castor_link"/>
    <child link="Rueda_castor_link"/>
    <axis xyz="${castor_wheel_axis}"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <joint name="Lidar_joint" type="fixed">
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="Lidar_link"/>
    <axis xyz="0 1 0" />
</joint>

  <!-- Fricción de las ruedas motrices para reducir deslizamiento en Gazebo -->
<gazebo reference="Rueda_izquierda_link">
  <mu1>2.0</mu1>
  <mu2>2.0</mu2>
  <kp>1e6</kp>    <kd>1.0</kd>
</gazebo>

<gazebo reference="Rueda_derecha_link">
  <mu1>2.0</mu1>
  <mu2>2.0</mu2>
  <kp>1e6</kp>
  <kd>1.0</kd>
</gazebo>

  <!-- Rueda castor con fricción mínima para que gire libre -->
<gazebo reference="Rueda_castor_link">
  <mu1>0.01</mu1>
  <mu2>0.01</mu2>
</gazebo>

</robot>