<?xml version="1.0"?>

<launch>

    <arg
        name="params_file"
        default="$(find-pkg-share my_robot_navigation)/config/nav2_params.yaml"
    />

    <node pkg="my_robot_navigation" exec="orchestrator" name="orchestrator" output="screen">
        <param from="$(var params_file)" />
    </node>

</launch>