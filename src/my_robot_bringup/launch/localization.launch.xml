<launch>
    <set_env name="GZ_SIM_RESOURCE_PATH" value="$(find-pkg-share my_robot_bringup)/worlds/models:$(find-pkg-share my_robot_description)/.." />

    <let name="urdf_path"
         value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro" />
    <let name="rviz_config_path"
         value="$(find-pkg-share my_robot_description)/rviz/rviz_localization.rviz" />

    <!-- ============ Argumentos ============ -->
    <arg name="world_path" default="$(find-pkg-share my_robot_bringup)/worlds/warehouse_world.sdf" />
    <arg name="map_path" default="$(find-pkg-share my_robot_bringup)/maps/warehouse_map_v1.yaml" />

    <!-- Punto de spawn del robot en el mundo -->
    <arg name="spawn_x" default="0.0" />
    <arg name="spawn_y" default="0.0" />

    <!-- Estado del robot -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />
        <param name="use_sim_time" value="true"/>
    </node>

    <!-- Gazebo: servidor + GUI separados (fix del choque de escenas) -->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(var world_path) -r -s" />
    </include>
    <executable cmd="gz sim -g" output="screen" />

    <!-- Spawn del robot -->
    <node pkg="ros_gz_sim" exec="create"
          args="-topic robot_description -x $(var spawn_x) -y $(var spawn_y) -z 0.1" />

    <!-- Puente ROS <-> Gazebo -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(find-pkg-share my_robot_bringup)/config/config.yaml" />
    </node>

    <!-- Map Server: carga el mapa guardado en Parte 1 -->
    <node pkg="nav2_map_server" exec="map_server" name="map_server" output="screen">
        <param name="yaml_filename" value="$(var map_path)" />
        <param name="use_sim_time" value="true" />
    </node>

    <!-- AMCL: localización dentro del mapa -->
    <node pkg="nav2_amcl" exec="amcl" name="amcl" output="screen">
        <param from="$(find-pkg-share my_robot_bringup)/config/amcl_params.yaml" />
        <param name="use_sim_time" value="true" />
    </node>

    <!-- Lifecycle Manager: gestiona map_server + amcl -->
    <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_localization" output="screen">
        <param name="use_sim_time" value="true" />
        <param name="autostart" value="true" />
        <param name="node_names" value="['map_server', 'amcl']" />
    </node>

    <!-- RViz -->
    <node pkg="rviz2" exec="rviz2" output="screen"
        args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="true" />
    </node>
</launch>